<Project>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>14</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <!-- Shared NuGet metadata for all packable projects in the repo -->
  <PropertyGroup>
    <Authors>ruberoid</Authors>
    <Company>musk.fun</Company>
    <PackageProjectUrl>https://github.com/ruberoid/stringly</PackageProjectUrl>
    <RepositoryUrl>https://github.com/ruberoid/stringly</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>fluent;strings;joke;stringly-typed;dsl</PackageTags>
    <Version>0.1.0</Version>
  </PropertyGroup>

</Project>
